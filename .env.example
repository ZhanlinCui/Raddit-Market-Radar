# MeDo Reddit Intelligence Radar — Environment Configuration
# Copy to .env and fill in. System runs in MOCK MODE with these defaults (no real creds needed).

# ---- Runtime ----
APP_ENV=local
LOG_LEVEL=INFO

# ---- Database ----
# Verifiable local slice uses SQLite. Switch to the Postgres URL for the full stack.
DATABASE_URL=sqlite+aiosqlite:///./medo_radar.db
# DATABASE_URL=postgresql+asyncpg://medo:medo@localhost:5432/medo_radar

# ---- Data source (Reddit) ----
# mock  -> MockRedditAdapter (reads fixtures/, no credentials required)
# reddit-> real Async PRAW adapter (requires the credentials below)
SOURCE_ADAPTER=mock
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=medo-radar/0.1 by your_reddit_user
REDDIT_USERNAME=
REDDIT_PASSWORD=

# ---- LLM provider ----
# mock              -> deterministic MockLLMProvider (no key required)
# openai-compatible -> OpenAI / Claude / ERNIE / any OpenAI-compatible endpoint
LLM_PROVIDER=mock
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL_L1=gpt-4o-mini
LLM_MODEL_L2=gpt-4o
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# ---- Embedding provider (P1) ----
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-3-small

# ---- Notification channels (optional) ----
FEISHU_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# ---- Scan defaults (all overridable per project) ----
SCAN_NEW_INTERVAL_MINUTES=10
SEARCH_INTERVAL_MINUTES=60
BACKFILL_INTERVAL_HOURS=6
HOT_LEAD_ALERT_THRESHOLD=85

# ---- Scheduler ----
# true -> in-process asyncio scheduler runs a scan for every Active project every
# SCAN_NEW_INTERVAL_MINUTES. false (default) -> manual /api/scan only.
SCHEDULER_ENABLED=false
